{
  "compilerOptions": {
    "types": ["vitest"],
    "target": "ESNext",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
		"module": "NodeNext",
		"moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "typeRoots": [
      "./node_modules/@types/", "./types", "./node_modules"
    ],
		"paths": {
			"mobx-tanstack-query": ["./src/index.ts"],
			"mobx-tanstack-query/preset": ["./src/preset/index.ts"]
		},
    "noEmit": false,
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*.test.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
